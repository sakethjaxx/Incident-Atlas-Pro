DATABASE_URL="postgresql://postgres:postgres@localhost:5432/incident_ingest?schema=public"
PORT=3001

# SEC-1: Restrict CORS to this origin (comma-separated for multiple).
# In dev this defaults to http://localhost:5173 if unset.
CORS_ORIGIN="http://localhost:5173"

# SEC-2: API key required in the x-ingest-api-key header for POST /ingest/manual.
# Leave empty in dev to skip the check (a warning will be logged).
INGEST_API_KEY=""
ADMIN_TOKEN="dev-secret"
REDIS_URL="redis://localhost:6379"
