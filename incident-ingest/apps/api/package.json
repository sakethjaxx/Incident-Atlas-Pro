{
  "name": "@app/api",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest run src/tests --reporter=verbose",
    "test:unit": "vitest run src/tests/parser.test.js src/tests/health.test.js --reporter=verbose",
    "test:integration": "vitest run src/tests --reporter=verbose",
    "test:coverage": "vitest run src/tests --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "dotenv": "^16.4.5",
    "prisma": "^5.18.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.9"
  }
}
